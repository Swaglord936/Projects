      "source": [
        "#@title Prediction of Premier English League (id 3) through MAY (In each currency)\n",
        "\n",
        "df[\"TransDate\"] = pd.to_datetime(df[\"TransDate\"])\n",
        "\n",
        "print(\"Full dataset range:\")\n",
        "print(df[\"TransDate\"].min(), df[\"TransDate\"].max())\n",
        "\n",
        "epl = df[df[\"LeagueId\"] == 3].copy()\n",
        "\n",
        "print(\"League 3 range:\")\n",
        "print(epl[\"TransDate\"].min(), epl[\"TransDate\"].max())\n",
        "\n",
        "\"\"\"\n",
        "Full dataset range:\n",
        "2025-03-11 15:37:10.830000 2025-04-30 16:51:34.247000\n",
        "League 3 range:\n",
        "2025-03-11 15:37:10.830000 2025-04-07 16:51:43.330000\n",
        "\"\"\"\n",
        "\n",
        "#Oh ok, we dont even have all of april here. I have 28 days of data\n",
        "#And I need to forecast May plus the rest of april. Its too little data\n",
        "#for a model to reliably capture a trend. For example, if this April was somewhat\n",
        "#abnormal, vs april of past years my model wouldnt know. If I at least had a\n",
        "#league with similar behavior to the Premier English one for which I also had data\n",
        "#for May, then maybe that would work as proxy for it, but as we see in the dataset\n",
        "#range it is not the case.\n",
        "#We have limited data and no explanatory variables.\n",
        "\n",
        "#Ok, the most reasonable thing to do is a baseline forecast.\n",
        "#This is not really a forecast, its more of a:\n",
        "#\"let me see a glimpse forward but be conservative\".\n",
        "#In other words...Yes, Im just using historical averages.\n",
        "\n",
        "#Probably the safest way to get close to May´s stake value\n",
        "\n",
        "#Lets remove time and just use day\n",
        "epl[\"Day\"] = epl[\"TransDate\"].dt.normalize()\n",
        "\n",
        "#Calendar range\n",
        "hist_start = epl[\"Day\"].min()\n",
        "hist_end = epl[\"Day\"].max()\n",
        "\n",
        "all_days = pd.date_range(hist_start, hist_end, freq=\"D\")\n",
        "currencies = epl[\"CurrencyStr\"].dropna().unique()\n",
        "\n",
        "#Daily stake by currency\n",
        "daily_epl = (\n",
        "    epl.groupby([\"CurrencyStr\", \"Day\"])\n",
        "       .agg(actual_stake=(\"Actual_Stake\", \"sum\"))\n",
        "       .reset_index()\n",
        ")\n",
        "\n",
        "#Full Currency x Day grid so missing days become 0\n",
        "full_grid = (\n",
        "    pd.MultiIndex.from_product(\n",
        "        [currencies, all_days],\n",
        "        names=[\"CurrencyStr\", \"Day\"]\n",
        "    )\n",
        "    .to_frame(index=False)\n",
        ")\n",
        "\n",
        "daily_epl_full = (\n",
        "    full_grid\n",
        "    .merge(daily_epl, on=[\"CurrencyStr\", \"Day\"], how=\"left\")\n",
        ")\n",
        "\n",
        "daily_epl_full[\"actual_stake\"] = daily_epl_full[\"actual_stake\"].fillna(0)\n",
        "\n",
        "#Average daily stake by currency\n",
        "avg_daily_by_currency = (\n",
        "    daily_epl_full.groupby(\"CurrencyStr\")\n",
        "                  .agg(\n",
        "                      historical_days=(\"Day\", \"count\"),\n",
        "                      historical_total_stake=(\"actual_stake\", \"sum\"),\n",
        "                      avg_daily_stake=(\"actual_stake\", \"mean\")\n",
        "                  )\n",
        "                  .reset_index()\n",
        ")\n",
        "\n",
        "#May \"forecast\": average daily stake x 31 days\n",
        "avg_daily_by_currency[\"may_forecast_actual_stake\"] = (\n",
        "    avg_daily_by_currency[\"avg_daily_stake\"] * 31\n",
        ")\n",
        "\n",
        "may_forecast = (\n",
        "    avg_daily_by_currency\n",
        "    .sort_values(\"may_forecast_actual_stake\", ascending=False)\n",
        ")\n",
        "\n",
        "print(may_forecast)\n",
        "\n",
        "#It will be a flat lineif plotted It is average flat daily stake projected into may, so\n",
        "#it is not a daily forecast, it is a monthly estimate.\n",
        "\n"
      ],
