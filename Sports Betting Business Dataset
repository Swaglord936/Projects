        "#Insight 4 - Volatility\n",
        "#I can use the sharpe ratio logic for this.\n",
        "#Return to risk ratio:\n",
        "\n",
        "material_days = by_day[by_day[\"stake_sgd\"] > by_day[\"stake_sgd\"].quantile(0.25)]\n",
        "\n",
        "avg_daily_margin = material_days[\"margin\"].mean()\n",
        "vol_daily_margin = material_days[\"margin\"].std()\n",
        "risk_adjusted_margin = avg_daily_margin / vol_daily_margin\n",
        "\n",
        "negative_day_rate = (material_days[\"profit_sgd\"] < 0).mean()\n",
        "\n",
        "print(\"Average daily margin:\", avg_daily_margin)\n",
        "print(\"Daily margin volatility:\", vol_daily_margin)\n",
        "print(\"Risk-adjusted margin:\", risk_adjusted_margin)\n",
        "print(\"Negative day rate:\", negative_day_rate)\n",
