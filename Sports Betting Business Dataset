        "\n",
        "print(\"Worst websites by profit\")\n",
        "print(by_web.sort_values(\"profit_sgd\", ascending=True).head(10))\n",
        "\n",
        "print(\"Top websites by stake/volume\")\n",
        "print(by_web.sort_values(\"stake_sgd\", ascending=False).head(10))\n"
