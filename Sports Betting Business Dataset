        "#Since we already saw player concentration in terms of profit,\n",
        "#maybe we can now start answering the question of:\n",
        "#Are most players concentrated in a few leagues?\n",
        "#That way we might know where the business would\n",
        "#want to focus their resources and attention.\n",
        "\n",
        "#Lets see user share (Username might be on multiple leagues,\n",
        "#considering count only on league where he/she made highest stake)\n",
        "df[\"User_Key\"] = df[\"WebId\"].astype(str) + \"_\" + df[\"UserName\"].astype(str)\n",
        "\n",
        "user_league = (\n",
        "    df.groupby([\"User_Key\", \"LeagueId\"])\n",
        "      .agg(stake_sgd=(\"Stake_SGD\", \"sum\"))\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "main_league_per_user = (\n",
        "    user_league.sort_values(\"stake_sgd\", ascending=False)\n",
        "               .drop_duplicates(subset=[\"User_Key\"], keep=\"first\")\n",
        ")\n",
        "\n",
        "main_league_summary = (\n",
        "    main_league_per_user.groupby(\"LeagueId\")\n",
        "      .agg(users=(\"User_Key\", \"nunique\"))\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "main_league_summary[\"exclusive_user_share\"] = (\n",
        "    main_league_summary[\"users\"] / main_league_per_user[\"User_Key\"].nunique()\n",
