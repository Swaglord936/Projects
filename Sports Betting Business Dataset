        "\"\"\"\n",
        "#groupby(\"League\")[\"Status\"]\n",
        "#I was gonna do np.where for profits but it seems since winlost\n",
        "#is just money returned, stake - winlost works\n",
        "#df[\"Profit\"] = df[\"Actual_Stake\"]-df[\"Winlost\"],\n",
        "#Cool, we do have a exchange rate col into sgd\n",
        "df[\"Profit\"]=(df[\"Actual_Stake\"]-df[\"Winlost\"])*df[\"ActualRate\"]\n",
        "print(df[\"Profit\"].head(5))\n",
        "League_Profit=df.groupby(\"LeagueId\")[\"Profit\"].sum().sort_values(ascending=False)\n",
        "Website_Profit=df.groupby(\"WebId\")[\"Profit\"].sum().sort_values(ascending=False)\n",
        "#print(League_Profit,Website_Profit)\n",
        "print(\"The top 5 most profitable league are: \",League_Profit.head(5))\n",
        "print(\"The top 5 most profitable website are: \",Website_Profit.head(5))\n",
        "\n",
        "#Profit is basic, but whats below too. The margins, how much each client is bringing,\n",
        "#and how clients we lose.\n",
        "\n",
        "df[\"Stake_SGD\"]=df[\"Actual_Stake\"]*df[\"ActualRate\"]\n",
        "\n",
        "#Named aggregation.\n",
        "#Seems like its form is:\" .agg(col_name=(source_col_in_df,aggregation_form))    \"\n",
        "brand_summary = (\n",
        "    df.groupby(\"WebId\")  # or WebId / Brand column\n",
        "      .agg(\n",
        "          bets=(\"TransId\", \"count\"),\n",
        "          players=(\"UserName\", \"nunique\"),\n",
        "          turnover=(\"Stake_SGD\", \"sum\"),\n",
        "          profit=(\"Profit\", \"sum\")\n",
        "      )\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "brand_summary[\"margin\"] = brand_summary[\"profit\"] / brand_summary[\"turnover\"]\n",
        "brand_summary[\"profit_per_player\"] = brand_summary[\"profit\"] / brand_summary[\"players\"]\n",
        "brand_summary[\"turnover_per_player\"] = brand_summary[\"turnover\"] / brand_summary[\"players\"]\n",
        "print(brand_summary)\n",
        "\n",
        "#Will be useful for website and league view, so lets make it reusable\n",
        "def summarize_by(df, col):\n",
        "    summary = (\n",
        "        df.groupby(col)\n",
        "          .agg(\n",
        "              bets=(\"TransId\", \"count\"),\n",
        "              players=(\"UserName\", \"nunique\"),\n",
        "              stake_sgd=(\"Stake_SGD\", \"sum\"),\n",
        "              profit_sgd=(\"Profit\", \"sum\"),\n",
        "          )\n",
        "          .reset_index()\n",
        "    )\n",
        "\n",
        "    summary[\"margin\"] = summary[\"profit_sgd\"] / summary[\"stake_sgd\"]\n",
        "    summary[\"stake_per_player\"] = summary[\"stake_sgd\"] / summary[\"players\"]\n",
        "    summary[\"profit_per_player\"] = summary[\"profit_sgd\"] / summary[\"players\"]\n",
        "    summary[\"bets_per_player\"] = summary[\"bets\"] / summary[\"players\"]\n",
        "\n",
        "    return summary\n",
        "#Website\n",
        "#summarize_by()\n",
        "#Leagure\n",
        "\n",
        "#df[\"Actual_Stake_SGD\"]=df[\"Actual_Stake\"]*[\"ActualRate\"]\n",
        "#df[\"Actual_Stake_SGD\"].agg()\n",
        "#sns.lineplot(data=df,x=\"TransDate\",y=\"Actual_Stake\",hue=\"WebId\")\n",
        "#plt.show()\n",
        "df[\"TransDate\"] = pd.to_datetime(df[\"TransDate\"])\n",
        "df[\"Month\"] = df[\"TransDate\"].dt.to_period(\"M\").astype(str)\n",
        "\n",
        "by_month = summarize_by(df, \"Month\")\n",
        "print(by_month)\n",
        "\n",
        "\"\"\"\n",
        "     Month    bets  players     stake_sgd    profit_sgd    margin  \\\n",
        "0  2025-03    3011     1733  8.998860e+04  2.297285e+04  0.255286\n",
        "1  2025-04  839152   108008  2.141095e+07  2.310697e+06  0.107921\n",
        "\"\"\"\n",
        "#Too many many more bets in Apr vs Mar\n",
        "#March is partially present, april is. Mar 11 - Apr 30.\n",
        "df[\"Day\"] = df[\"TransDate\"].dt.date\n",
        "\n",
        "by_day = (\n",
        "    df.groupby(\"Day\")\n",
        "      .agg(\n",
        "          bets=(\"TransId\", \"count\"),\n",
        "          players=(\"UserName\", \"nunique\"),\n",
        "          stake_sgd=(\"Stake_SGD\", \"sum\"),\n",
        "          profit_sgd=(\"Profit\", \"sum\")\n",
        "      )\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "by_day[\"margin\"] = by_day[\"profit_sgd\"] / by_day[\"stake_sgd\"]\n",
        "by_day[\"stake_per_player\"] = by_day[\"stake_sgd\"] / by_day[\"players\"]\n",
        "by_day[\"profit_per_player\"] = by_day[\"profit_sgd\"] / by_day[\"players\"]\n",
        "by_day[\"bets_per_player\"] = by_day[\"bets\"] / by_day[\"players\"]\n",
        "print(by_day)\n",
        "\n",
        "#Stuff might be more clear with a plot\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(by_day[\"Day\"], by_day[\"stake_sgd\"])\n",
        "plt.xticks(rotation=45)\n",
        "plt.title(\"Daily Stake SGD\")\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(by_day[\"Day\"], by_day[\"margin\"])\n",
        "plt.xticks(rotation=45)\n",
        "plt.title(\"Daily Margin\")\n",
        "plt.show()\n",
        "\n",
        "#Ok, so from plots I can see March is not useful. At least stakewise.\n",
        "\n",
        "by_day.sort_values(\"stake_sgd\", ascending=False).head(10)\n",
        "by_day.sort_values(\"profit_sgd\", ascending=True).head(10)\n",
        "by_day.sort_values(\"margin\", ascending=True).head(10)\n",
        "\n",
        "material_days = by_day[by_day[\"stake_sgd\"] > by_day[\"stake_sgd\"].quantile(0.25)]\n",
        "\n",
        "#Hm, I will simplify insights to these:\n",
        "\"\"\"\n",
        "1. Website performance\n",
        "2. League performance\n",
        "3. High-volume but low-margin segments\n",
        "4. Player concentration\n",
        "5. Daily volatility / risky days\n",
        "\"\"\"\n",
        "#Let me just create an explicit payout in sdg to avoid confusion\n",
        "df[\"Payout_SGD\"] = df[\"Winlost\"] * df[\"ActualRate\"]\n",
        "\n",
        "status_summary = (\n",
        "    df.groupby(\"Status\")\n",
        "      .agg(\n",
        "          bets=(\"TransId\", \"count\"),\n",
        "          stake_sgd=(\"Stake_SGD\", \"sum\"),\n",
        "          payout_sgd=(\"Payout_SGD\", \"sum\"),\n",
        "          profit=(\"Profit\", \"sum\")\n",
        "      )\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "status_summary[\"margin\"] = status_summary[\"profit\"] / status_summary[\"stake_sgd\"]\n",
        "\n",
        "print(status_summary.sort_values(\"profit\", ascending=False))\n",
        "\n",
        "# =========================\n",
        "# 1. Website performance\n",
        "# =========================\n",
        "\n",
        "by_web = summarize_by(df, \"WebId\")\n",
